; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Godot MCP Test"
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")

[godot_mcp]

runtime/direct_server=true

[autoload]

MCPGameInspector="*res://addons/godot_mcp/services/game_inspector.gd"
MCPGameInput="*res://addons/godot_mcp/services/game_input.gd"

[display]

window/size/viewport_width=2560
window/size/viewport_height=1440

[editor_plugins]

enabled=PackedStringArray("res://addons/godot_mcp/plugin.cfg")
